# SimpleSurvey backend environment template
# Used by backend/internal/config/config.go (godotenv.Load)

APP_ENV=development
SERVER_PORT=8080

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=simple_survey

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=simple_survey

JWT_SECRET=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRES_HOURS=24
REFRESH_TOKEN_EXPIRES_HOURS=168
REQUEST_TIMEOUT_SECONDS=10

# Comma-separated origins, e.g. http://localhost:3000
CORS_ALLOWED_ORIGINS=*

# Frontend build-time API base URL (consumed by Vite in Docker build)
FRONTEND_API_BASE_URL=/api/v1

# Optional admin bootstrap
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
